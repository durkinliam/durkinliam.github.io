---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Liam Durkin">
    <div class="terminal-window">
        <div class="terminal-inner-window bg-gray-800 text-gray-100 text-sm font-mono pb-6 pt-4 rounded-lg">
            <div class="terminal-button-layer pl-4 flex">
                <div class="close-terminal-button bg-red-500 h-3 w-3 rounded-full"></div>
                <div class="minimise-terminal-button bg-orange-300 ml-2 h-3 w-3 rounded-full"></div>
                <div class="full-sreen-terminal-button bg-green-500 ml-2 h-3 w-3 rounded-full"></div>
            </div>
            <div class="terminal-content-layer pl-4 mt-4 flex">
                <p class="index-terminal-typing"/>
            </div>
        </div>
    </div>

    <script>
        const greetings = ["Hello, World!", "This site is currently under construction.", "Welcome to my website.", "I'm Liam Durkin, currently a senior software engineer working at Flutter.", "Please get in touch if you want to chat."];
        const typingElements = document.querySelectorAll('.index-terminal-typing');

        typingElements.forEach(typingElement => {
            let greetingIndex = 0;
            let charIndex = 0;

            function typeText() {
                if (greetingIndex < greetings.length) {
                    if (charIndex < greetings[greetingIndex].length) {
                        typingElement.innerHTML += greetings[greetingIndex][charIndex];
                        charIndex++;
                        setTimeout(typeText, 100);
                    } else {
                        typingElement.innerHTML += '<br/><span class="subsequent-terminal-line text-green-400">Liam Durkin:~$ </span><span class="index-terminal-typing"></span>';
                        charIndex = 0;
                        greetingIndex++;
                        setTimeout(typeText, 200);
                    }
                }
            }

            typingElement.innerHTML = '<span class="initial-terminal-line text-green-400">Liam Durkin:~$ </span><span class="index-terminal-typing"></span>';
            typeText();
        });
    </script>
</Layout>